<form method="post" action="{{ path('app_card_delete', {'id': card.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette annonce ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ card.id) }}">
    <button class="btn btn-danger rounded-pill px-4">
        <i class="bi bi-trash me-1"></i> Supprimer l'annonce
    </button>
</form>