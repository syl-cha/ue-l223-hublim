{# 1. Début du formulaire avec Turbo désactivé pour éviter les conflits de validation #}
{{ form_start(form, {
    'attr': {
        'class': 'announce-form', 
        'enctype': 'multipart/form-data', 
        'data-turbo': 'false'
    }
}) }}
    {% if not form.vars.valid %}
        <div class="alert alert-danger announce-alert" role="alert">
            Merci de corriger les champs en erreur avant de publier l'annonce.
            {# Affichage des erreurs globales si PHP post_max_size est dépassé #}
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <div class="row g-4">
        <div class="col-12">
            <div class="announce-card-section">
                {{ form_label(form.title) }}
                {{ form_widget(form.title) }}
                {{ form_errors(form.title) }}
            </div>
        </div>

        <div class="col-12">
            <div class="announce-card-section">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>
        </div>

        <div class="col-12">
            <div class="announce-card-section">
                <h5 class="fw-bold mb-3">Gestion des photos</h5>

                {# --- PHOTOS EXISTANTES --- #}
                {% if card.images is not empty %}
                    <div class="row g-2 mb-3">
                        {% for image in card.images %}
                            <div class="col-4" id="photo-{{ image.id }}">
                                <div class="position-relative">
                                    <img src="/uploads/cards/{{ image.fileName }}" 
                                         class="w-100 rounded-2 shadow-sm" 
                                         style="height:100px; object-fit:cover;">
                                    
                                    <button type="button" 
                                            class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 rounded-circle btn-mark-delete" 
                                            data-image-id="{{ image.id }}">
                                        <i class="bi bi-x"></i>
                                    </button>

                                    {# CORRECTION : Le nom doit être image_carte pour correspondre à ton Controller #}
                                    <input type="checkbox" 
                                           name="image_carte[delete_images][]" 
                                           value="{{ image.id }}" 
                                           id="delete-{{ image.id }}" 
                                           class="d-none">
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {# --- AJOUT DE NOUVELLES PHOTOS --- #}
                <div class="mt-2">
                    {{ form_label(form.imageFiles, "Ajouter des photos", {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.imageFiles, {'attr': {'class': 'form-control', 'id': 'card_imageFiles'}}) }}
                    {{ form_errors(form.imageFiles) }}
                    <small class="text-muted">Max 10 photos au total.</small>
                </div>

                {# Zone de prévisualisation gérée par le JS #}
                <div id="preview-grid" class="row g-2 mt-2"></div>
            </div>
        </div>

        {# Section Notes / Status / StudyFields #}
        <div class="col-lg-6">
            <div class="announce-card-section h-100 announce-side-note">
                <h3>Avant de publier</h3>
                <p class="mb-2">Vérifie que ton annonce est complète et claire.</p>
            </div>
        </div>

        <div class="col-12">
            <div class="announce-card-section">
                <div class="announce-group-title">{{ form_label(form.targetStatus) }}</div>
                <div class="announce-choice-grid">
                    {% for child in form.targetStatus %}
                        <label class="announce-choice-card">
                            {{ form_widget(child) }}
                            <span>{{ child.vars.label }}</span>
                        </label>
                    {% endfor %}
                </div>
                {{ form_errors(form.targetStatus) }}
            </div>
        </div>


        <div class="col-12">
            <div class="announce-card-section">
                <div class="announce-group-title">{{ form_label(form.targetStudyFields) }}</div>
                <div class="studyfield-dropdown" data-studyfield-dropdown>
                    <button type="button" class="studyfield-dropdown-toggle">
                        <span class="studyfield-dropdown-text">Sélectionner les filières</span>
                        <span class="studyfield-dropdown-arrow">▾</span>
                    </button>
                    <div class="studyfield-dropdown-menu">
                        {# Boutons tout sélectionner / tout désélectionner #}
                        <div class="d-flex gap-2 p-2 border-bottom">
                            <button type="button" class="btn btn-sm btn-outline-primary rounded-pill" id="btn-select-all">
                                Tout sélectionner
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" id="btn-deselect-all">
                                Tout désélectionner
                            </button>
                        </div>

                        {% set selectedIds = [] %}
                        {% for field in card.targetStudyFields %}
                            {% set selectedIds = selectedIds|merge([field.id]) %}
                        {% endfor %}

                        {% for type, themes in studyFieldsGrouped %}
                            <div class="studyfield-type-group">
                                <button type="button" class="studyfield-type-toggle">
                                    {{ type }}
                                    <span class="studyfield-type-arrow">▾</span>
                                </button>
                                <div class="studyfield-type-content">
                                    {% for theme, fields in themes %}
                                        <div class="studyfield-theme-group">
                                            <div class="studyfield-theme-label">{{ theme }}</div>
                                            {% for field in fields %}
                                                <label class="studyfield-dropdown-item">
                                                    <input type="checkbox"
                                                        name="card[targetStudyFields][]"
                                                        value="{{ field.id }}"
                                                        class="studyfield-checkbox"
                                                        {% if field.id in selectedIds %}checked{% endif %}>
                                                    <span>{{ field.name }}</span>
                                                </label>
                                            {% endfor %}
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                {% do form.targetStudyFields.setRendered() %}
                {{ form_errors(form.targetStudyFields) }}
            </div>
        </div>

    {{ form_rest(form) }}

    <div class="announce-actions d-flex justify-content-end gap-3 mt-4">
        <a href="{{ path('app_card_index') }}" class="btn btn-light rounded-pill px-4">Annuler</a>
        <button type="submit" class="btn btn-orange rounded-pill px-4">
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>
{{ form_end(form) }}