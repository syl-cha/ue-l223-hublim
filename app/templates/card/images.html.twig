{% extends 'base.html.twig' %}

{% block title %}Photos - {{ card.title }}{% endblock %}

{% block body %}
<div class="container px-4 py-5" style="max-width: 760px;">

    <a href="{{ path('app_card_show', {id: card.id}) }}" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
        <i class="bi bi-arrow-left"></i> Retour à l'annonce
    </a>

    <h1 class="fw-bold text-primary raleway-500 mb-4">Photos de l'annonce</h1>

    {# Photos existantes #}
    {% if card.images is not empty %}
    <div class="row g-3 mb-5">
        {% for image in card.images %}
        <div class="col-4">
            <div class="position-relative">
                <img src="/uploads/cards/{{ image.fileName }}"
                     alt="{{ image.alt ?? card.title }}"
                     class="w-100 rounded-3"
                     style="height: 140px; object-fit: cover;">
                <form method="post"
                      action="{{ path('app_card_image_delete', {id: image.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-image-' ~ image.id) }}">
                    <button type="submit"
                            class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 rounded-circle"
                            style="width:28px; height:28px; padding:0; line-height:1;"
                            onclick="return confirm('Supprimer cette photo ?')">
                        <i class="bi bi-x"></i>
                    </button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <p class="text-muted mb-4">Aucune photo pour le moment.</p>
    {% endif %}

    {# Formulaire upload #}
    <div class="shadow-sm rounded-4 p-4 bg-white">
        <h5 class="fw-bold text-primary raleway-500 mb-3">Ajouter des photos</h5>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
            {{ form_row(form.imageFiles) }}
            <button type="submit" class="btn btn-orange rounded-pill mt-3">
                <i class="bi bi-upload"></i> Uploader
            </button>
        {{ form_end(form) }}
    </div>

</div>
{% endblock %}