{% extends 'base.html.twig' %}

{% block title %}{{ card.title }} - HubLim{% endblock %}

{% block body %}
<div class="container px-4 py-5">

    <a href="{{ path('app_card_index') }}" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
        <i class="bi bi-arrow-left"></i> Retour aux annonces
    </a>

    <div class="row g-4">
        {# Colonne principale #}
        <div class="col-lg-8">
            <div class="shadow-sm rounded-4 p-4 bg-white">

                {# En-tête : auteur + date #}
                <div class="d-flex align-items-center mb-3">
                    <div class="user-avatar me-3" style="width:48px; height:48px; font-size:22px;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div>
                        <div class="fw-bold">{{ card.user.firstName }} {{ card.user.lastName }}</div>
                        <div class="text-muted" style="font-size:0.82rem;">
                            Publiée le {{ card.createdAt|date('d/m/Y') }} à {{ card.createdAt|date('H:i') }}
                            {% if card.updatedAt %}
                                | Modifiée le {{ card.updatedAt|date('d/m/Y') }}
                            {% endif %}
                        </div>
                    </div>
                </div>

                {# Titre #}
                <h1 class="fw-bold text-primary raleway-500 mb-3" style="font-size:1.8rem;">{{ card.title }}</h1>

                {# Description #}
                <div style="font-size:1rem; line-height:1.8; color:#374151;">
                    {{ card.description|nl2br }}
                </div>

                {% if card.images is not empty %}
                {% set images = card.images %}
                {% set count = images|length %}

                <div class="fb-gallery mb-4" id="fb-gallery">

                {% if count == 1 %}
                    <div class="fb-gallery-single">
                        <img src="/uploads/cards/{{ images[0].fileName }}"
                            alt="{{ images[0].alt ?? card.title }}"
                            class="fb-img" data-index="0">
                    </div>

                    {% elseif count == 2 %}
                        <div class="fb-gallery-two">
                            {% for i in 0..1 %}
                                <img src="/uploads/cards/{{ images[i].fileName }}"
                                    alt="{{ images[i].alt ?? card.title }}"
                                    class="fb-img" data-index="{{ i }}">
                            {% endfor %}
                        </div>

                    {% else %}
                        <div class="fb-gallery-three">
                            <div class="fb-main">
                                <img src="/uploads/cards/{{ images[0].fileName }}"
                                    alt="{{ images[0].alt ?? card.title }}"
                                    class="fb-img" data-index="0">
                            </div>
                            <div class="fb-side">
                                <div class="fb-side-top">
                                    <img src="/uploads/cards/{{ images[1].fileName }}"
                                        alt="{{ images[1].alt ?? card.title }}"
                                        class="fb-img" data-index="1">
                                </div>
                                <div class="fb-side-bottom">
                                    <img src="/uploads/cards/{{ images[2].fileName }}"
                                        alt="{{ images[2].alt ?? card.title }}"
                                        class="fb-img" data-index="2">
                                    {% if count > 3 %}
                                        <div class="fb-overlay" data-index="2">
                                            +{{ count - 3 }}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endif %}

                </div>

                {# Lightbox — sans onclick inline #}
                <div id="lightbox" class="lb-backdrop">
                    <button class="lb-close" id="lb-close">✕</button>
                    <button class="lb-prev" id="lb-prev">&#8249;</button>
                    <div class="lb-content">
                        <img id="lb-img" src="" alt="">
                        <div id="lb-counter" class="lb-counter"></div>
                    </div>
                    <button class="lb-next" id="lb-next">&#8250;</button>
                </div>

                {% endif %}

                {% if app.user == card.user and form is not null %}
                <div class="mt-3">
                    <button class="btn btn-outline-secondary btn-sm rounded-pill"
                            type="button"
                            onclick="document.getElementById('panel-images').classList.toggle('d-none')">
                        <i class="bi bi-images"></i> Gérer les photos
                    </button>

                    <div id="panel-images" class="d-none mt-3 p-3 rounded-3 border bg-light">

                        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'id': 'form-images', 'data-turbo': 'false', 'autocomplete': 'off'}}) }}

                            {# Photos existantes #}
                            {% if card.images is not empty %}
                            <div class="row g-2 mb-3" id="photos-grid">
                                {% for image in card.images %}
                                <div class="col-4 photo-item" id="photo-{{ image.id }}">
                                    <div class="position-relative">
                                        <img src="/uploads/cards/{{ image.fileName }}"
                                            alt="{{ image.alt ?? card.title }}"
                                            class="w-100 rounded-2"
                                            style="height: 100px; object-fit: cover;">
                                        {# Overlay suppression #}
                                        <div class="photo-delete-overlay d-none position-absolute inset-0 rounded-2"
                                            style="inset:0; background:rgba(220,53,69,0.6); display:none !important;">
                                            <i class="bi bi-trash text-white" style="font-size:1.5rem;"></i>
                                        </div>
                                        {# Bouton croix #}
                                        <button type="button"
                                                class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 rounded-circle btn-mark-delete"
                                                data-image-id="{{ image.id }}"
                                                style="width:24px; height:24px; padding:0; line-height:1; font-size:0.7rem;">
                                            <i class="bi bi-x"></i>
                                        </button>
                                        {# Input caché pour la suppression #}
                                       <input type="checkbox" name="image_carte[delete_images][]" value="{{ image.id }}"
                                            id="delete-{{ image.id }}" class="d-none delete-checkbox">
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                            {% endif %}

                            {# Upload #}
                            {{ form_label(form.imageFiles) }}
                            {% set remaining = 10 - card.images|length %}
                            {% if remaining <= 0 %}
                                <p class="text-danger small mb-2"><i class="bi bi-exclamation-circle"></i> Limite de 10 photos atteinte.</p>
                            {% else %}
                                <p class="text-muted small mb-2">{{ remaining }} photo{{ remaining > 1 ? 's' : '' }} restante{{ remaining > 1 ? 's' : '' }}</p>
                            {% endif %}
                            <div class="mt-2">
                                {{ form_widget(form.imageFiles) }}
                            </div>
                            {{ form_errors(form.imageFiles) }}

                            <button type="submit" class="btn btn-orange btn-sm rounded-pill mt-3">
                                <i class="bi bi-check-lg"></i> Enregistrer
                            </button>

                        {{ form_end(form) }}
                    </div>
                </div>
                {% endif %}


            </div>
        </div>

        {# Colonne latérale #}
        <div class="col-lg-4">
            {# Infos #}
            <div class="shadow-sm rounded-4 p-4 bg-white mb-4">
                <h5 class="fw-bold text-primary raleway-500 mb-3">Informations</h5>

                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-tag-fill me-2 text-secondary"></i>
                    <div>
                        <small class="text-muted d-block">Catégorie</small>
                        <span class="fw-semibold">{{ card.category ? card.category.name : 'Non définie' }}</span>
                    </div>
                </div>

                {% if card.targetStatus|length > 0 %}
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-mortarboard-fill me-2 text-secondary mt-1"></i>
                        <div>
                            <small class="text-muted d-block">Statuts ciblés</small>
                            {% for status in card.targetStatus %}
                                <span class="badge rounded-pill" style="background-color: var(--color-primary);">{{ status.label.value }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {% if card.targetStudyFields|length > 0 %}
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-book-fill me-2 text-secondary mt-1"></i>
                        <div>
                            <small class="text-muted d-block">Filières ciblées</small>
                            {% for field in card.targetStudyFields %}
                                <span class="badge rounded-pill" style="background-color: var(--color-ternary); color: var(--color-primary);">{{ field.name }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                <div class="d-flex align-items-center mb-3">
                    <span class="me-2">⭐</span>
                    <div>
                        <small class="text-muted d-block">Favoris</small>
                        <span class="fw-semibold">{{ card.fanUsers|length }} personne{{ card.fanUsers|length > 1 ? 's' : '' }}</span>
                    </div>
                </div>
            </div>

            {# Actions #}
            <div class="shadow-sm rounded-4 p-4 bg-white mb-4">
                <h5 class="fw-bold text-primary raleway-500 mb-3">Actions</h5>
                <div class="d-grid gap-2">
                    <a href="mailto:{{ card.user.email }}" class="btn btn-orange rounded-pill">
                        <i class="bi bi-envelope-fill"></i> Contacter l'auteur
                    </a>
                </div>
            </div>

            {# Auteur #}
            <div class="shadow-sm rounded-4 p-4 bg-white">
                <h5 class="fw-bold text-primary raleway-500 mb-3">A propos de l'auteur</h5>
                <div class="text-center">
                    <div class="user-avatar mx-auto mb-2" style="width:64px; height:64px; font-size:28px;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div class="fw-bold">{{ card.user.firstName }} {{ card.user.lastName }}</div>
                    {% if card.user.status %}
                        <small class="text-muted">{{ card.user.status.label.value }}</small>
                    {% endif %}
                    {% if card.user.studyField %}
                        <br><small class="text-muted">{{ card.user.studyField.name }}</small>
                    {% endif %}
                    <div class="text-muted mt-1" style="font-size:0.78rem;">
                        Membre depuis {{ card.user.createdAt|date('m/Y') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% if card.images is not empty %}
<script>
    window.galleryImages = [
        {% for image in card.images %}
        { src: "/uploads/cards/{{ image.fileName }}", alt: "{{ image.alt ?? card.title|e('js') }}" }{{ not loop.last ? ',' : '' }}
        {% endfor %}
    ];
    console.log('Images chargées :', window.galleryImages);
</script>
{% endif %}

{% endblock %}
