{% extends 'base.html.twig' %}

{% block title %}{{ card.title }} - HubLim{% endblock %}
{% block body_class %}bg-gris{% endblock %}
{% block body %}
<div class="container px-4 py-5">

    <a href="{{ path('app_card_index') }}" class="btn btn-outline-secondary rounded-pill px-4 mb-4">
        <i class="bi bi-arrow-left"></i> Retour aux annonces
    </a>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    {# ── Bannière brouillon ── #}
    {% if card.state.value == 'draft' and app.user == card.user %}
        <div class="alert d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4 rounded-4 px-4 py-3" style="background-color: #f3f4f6; border: 2px dashed #9ca3af;">
            <div class="d-flex align-items-center gap-2 text-muted fw-semibold">
                <i class="bi bi-floppy-fill"></i>
                Cette annonce est un brouillon — elle n'est pas visible par les autres utilisateurs.
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="{{ path('app_card_index', {'tab': 'drafts'}) }}"
                class="btn btn-outline-secondary rounded-pill px-3">
                    <i class="bi bi-arrow-left me-1"></i> Mes brouillons
                </a>
                <a href="{{ path('app_card_edit', {'id': card.id}) }}"
                class="btn btn-outline-primary rounded-pill px-3">
                    <i class="bi bi-pencil me-1"></i> Éditer
                </a>
                <form method="post" action="{{ path('app_card_publish', {'id': card.id}) }}" style="display:contents">
                    <input type="hidden" name="_token" value="{{ csrf_token('publish' ~ card.id) }}">
                    <button type="submit" class="btn btn-orange rounded-pill px-3">
                        <i class="bi bi-send me-1"></i> Publier
                    </button>
                </form>
            </div>
        </div>
    {% endif %}

    <div class="row g-4">
        {# Colonne principale #}
        <div class="col-lg-8" data-controller="reagir">
            <div class="shadow-sm rounded-4 p-4 bg-white position-relative">

                {# En-tête : auteur + date + Menu Actions #}
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center">
                        <div class="user-avatar me-3" style="width:48px; height:48px; font-size:22px;">
                            {% if card.user.avatarFileName %}
                                <img src="{{ asset('uploads/avatars/' ~ card.user.avatarFileName) }}"
                                    alt="{{ card.user.firstName }}"
                                    style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                            {% else %}
                                <i class="bi bi-person-fill"></i>
                            {% endif %}
                        </div>
                        <div>
                            <div class="fw-bold">{{ card.user.firstName }} {{ card.user.lastName }}</div>
                            <div class="text-muted" style="font-size:0.82rem;">
                                {% if card.state.value == 'draft' %}
                                    Brouillon créé le {{ card.createdAt|date('d/m/Y') }} à {{ card.createdAt|date('H:i') }}
                                {% else %}
                                    Publiée le {{ card.createdAt|date('d/m/Y') }} à {{ card.createdAt|date('H:i') }}
                                {% endif %}
                                {% if card.updatedAt %}
                                    | Modifiée le {{ card.updatedAt|date('d/m/Y') }}
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# Menu 3 petits points (visible uniquement par l'auteur ou l'admin) #}
                    {% if app.user == card.user or is_granted('ROLE_ADMIN') %}
                        <div class="dropdown">
                            <button class="btn btn-link text-dark shadow-none p-0 dropdown-toggle-split"
                                    type="button"
                                    id="dropdownMenuCard"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    style="font-size: 1.5rem; line-height: 1;">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3" aria-labelledby="dropdownMenuCard">
                                <li>
                                    <a class="dropdown-item py-2" href="{{ path('app_card_edit', {'id': card.id}) }}">
                                        <i class="bi bi-pencil me-2 text-primary"></i> Modifier l'annonce
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" action="{{ path('app_card_delete', {'id': card.id}) }}"
                                        onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette annonce ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ card.id) }}">
                                        <button type="submit" class="dropdown-item py-2 text-danger">
                                            <i class="bi bi-trash me-2"></i> Supprimer l'annonce
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    {% endif %}
                </div>

                {# Titre #}
                <h1 class="fw-bold text-primary raleway-500 mb-3" style="font-size:1.8rem;">{{ card.title }}</h1>

                {# Description #}
                <div class="markdown-content">
                    {{ card.description|markdown_to_html|sanitize_html }}
                </div>

                {% if card.images is not empty %}
                {% set images = card.images %}
                {% set count = images|length %}

                <div class="fb-gallery mb-4" id="fb-gallery">

                {% if count == 1 %}
                    <div class="fb-gallery-single">
                        <img src="{{ '/uploads/cards/' ~ images[0].fileName ~ '-medium.webp' }}"
                            alt="{{ images[0].alt ?? card.title }}"
                            class="fb-img" data-index="0">
                    </div>

                {% elseif count == 2 %}
                    <div class="fb-gallery-two">
                        {% for i in 0..1 %}
                            <img src="{{ '/uploads/cards/' ~ images[i].fileName ~ '-medium.webp' }}"
                                alt="{{ images[i].alt ?? card.title }}"
                                class="fb-img" data-index="{{ i }}">
                        {% endfor %}
                    </div>

                {% else %}
                    <div class="fb-gallery-three">
                        <div class="fb-main">
                            <img src="{{ '/uploads/cards/' ~ images[0].fileName ~ '-medium.webp' }}"
                                alt="{{ images[0].alt ?? card.title }}"
                                class="fb-img" data-index="0">
                        </div>
                        <div class="fb-side">
                            <div class="fb-side-top">
                                <img src="{{ '/uploads/cards/' ~ images[1].fileName ~ '-medium.webp' }}"
                                    alt="{{ images[1].alt ?? card.title }}"
                                    class="fb-img" data-index="1">
                            </div>
                            <div class="fb-side-bottom">
                                <img src="{{ '/uploads/cards/' ~ images[2].fileName ~ '-medium.webp' }}"
                                    alt="{{ images[2].alt ?? card.title }}"
                                    class="fb-img" data-index="2">
                                {% if count > 3 %}
                                    <div class="fb-overlay" data-index="2">
                                        +{{ count - 3 }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endif %}

                </div>

                {# Lightbox #}
                <div id="lightbox" class="lb-backdrop">
                    <button class="lb-close" id="lb-close">✕</button>
                    <button class="lb-prev" id="lb-prev">&#8249;</button>
                    <div class="lb-content">
                        <img id="lb-img" src="" alt="">
                        <div id="lb-counter" class="lb-counter"></div>
                    </div>
                    <button class="lb-next" id="lb-next">&#8250;</button>
                </div>
                {% endif %}

                {# Bouton Favori #}
                {% if card.state.value == 'published' %}
                    {% if app.user %}
                        <a href="{{ path('app_card_favorite', {'id': card.id}) }}" class="btn bg-white rounded-circle position-absolute shadow-sm d-flex align-items-center justify-content-center border" style="bottom: -20px; left: 30px; z-index: 10; width: 42px; height: 42px; color: var(--color-jaune, #ffc107); font-size: 1.2rem;" title="Mettre en favori">
                            {% if app.user in card.fanUsers %}
                                <i class="bi bi-star-fill"></i>
                            {% else %}
                                <i class="bi bi-star"></i>
                            {% endif %}
                        </a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn bg-white rounded-circle position-absolute shadow-sm d-flex align-items-center justify-content-center border" style="bottom: -20px; left: 30px; z-index: 10; width: 42px; height: 42px; color: var(--color-jaune, #ffc107); font-size: 1.2rem;" title="Mettre en favori">
                            <i class="bi bi-star"></i>
                        </a>
                    {% endif %}
                {% endif %}

                {# Bouton Réagir #}
                {% if card.state.value == 'published' %}
                    {% if app.user %}
                        <button class="btn btn-primary rounded-pill position-absolute shadow-sm" style="bottom: -20px; right: 30px; z-index: 10;" data-action="click->reagir#toggle">
                            <i class="bi bi-chat-dots-fill me-1"></i> Réagir
                        </button>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-primary rounded-pill position-absolute shadow-sm" style="bottom: -20px; right: 30px; z-index: 10;">
                            <i class="bi bi-chat-dots-fill me-1"></i> Réagir
                        </a>
                    {% endif %}
                {% endif %}
            </div>

            {# Formulaire de création de message #}
            {% if app.user and message_form is defined and card.state.value == 'published' %}
                <div class="shadow-sm rounded-4 p-4 bg-white mt-4 d-none" data-reagir-target="form">
                    <h5 class="fw-bold text-primary mb-3">Laisser un message</h5>
                    <div>
                        {{ form_start(message_form) }}
                            <div class="mb-3">
                                {{ form_label(message_form.content, null, {'label_attr': {'class': 'form-label fw-bold text-dark'}}) }}
                                {{ form_widget(message_form.content, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
                                {{ form_errors(message_form.content) }}
                            </div>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-send-fill me-1"></i> Envoyer
                            </button>
                        {{ form_end(message_form) }}
                    </div>
                </div>
            {% endif %}

            {# Liste des messages #}
            <div class="mt-5">
                <h4 class="fw-bold mb-4">Messages ({{ card.messages|length }})</h4>

                {% set sorted_messages = card.messages|sort((a, b) => a.createdAt <=> b.createdAt) %}

                {% for message in sorted_messages %}
                    <div class="shadow-sm rounded-4 p-4 bg-white mb-3 position-relative border-start border-4 border-primary">
                        <div class="d-flex justify-content-between mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-avatar" style="width:36px; height:36px; font-size:16px; flex-shrink:0;">
                                    {% if message.user.avatarFileName %}
                                        <img src="{{ asset('uploads/avatars/' ~ message.user.avatarFileName) }}"
                                            alt="{{ message.user.firstName }}"
                                            style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                                    {% else %}
                                        <i class="bi bi-person-fill"></i>
                                    {% endif %}
                                </div>
                                <div>
                                    <strong class="text-primary">{{ message.user.firstName }} {{ message.user.lastName }}</strong>
                                    {% if message.user == card.user %}
                                        <span class="badge rounded-pill ms-1" style="background-color: var(--color-ternary);" title="Auteur de l'annonce">
                                            <i class="bi bi-megaphone-fill"></i>
                                        </span>
                                    {% endif %}
                                    <small class="text-muted ms-2">{{ message.createdAt|date('d/m/Y à H:i') }}</small>
                                </div>
                            </div>
                            {% if app.user and app.user == message.user and not message.isRead %}
                                <a href="{{ path('app_message_edit', {'id': message.id}) }}" class="btn btn-sm btn-outline-secondary rounded-pill">
                                    <i class="bi bi-pencil-fill"></i> Corriger
                                </a>
                            {% endif %}
                        </div>
                        <div class="mb-0 markdown-content">
                            {{ message.content|markdown_to_html|sanitize_html }}
                        </div>
                    </div>
                {% else %}
                    <p class="text-muted fst-italic">Aucun message pour l'instant. Soyez le premier à réagir !</p>
                {% endfor %}
            </div>
            </div>

        {# Colonne latérale #}
        <div class="col-lg-4">
            {# Infos #}
            <div class="shadow-sm rounded-4 p-4 bg-white mb-4">
                <h5 class="fw-bold text-primary raleway-500 mb-3">Informations</h5>

                <div class="d-flex align-items-center mb-3">
                    {% set color = card.category ? (card.category.parent ? card.category.parent.color : card.category.color) : null %}
                    <i class="bi bi-tag-fill me-2" style="{{ color ? 'color:' ~ color : 'color: var(--color-secondary)' }}"></i>
                    <div>
                        {% if card.category %}
                            {% if card.category.parent %}
                                <span class="fw-semibold" style="color: {{ color }}">{{ card.category.parent.name }}</span>
                                <small class="text-muted d-block">{{ card.category.name }}</small>
                            {% else %}
                                <span class="fw-semibold" style="color: {{ color }}">{{ card.category.name }}</span>
                            {% endif %}
                        {% else %}
                            <span class="fw-semibold text-muted">Non définie</span>
                        {% endif %}
                    </div>
                </div>

                {% if card.targetStatus|length > 0 %}
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-mortarboard-fill me-2 text-secondary mt-1"></i>
                        <div>
                            <small class="text-muted d-block">Statuts ciblés</small>
                            {% for status in card.targetStatus %}
                                <span class="badge rounded-pill" style="background-color: var(--color-primary);">{{ status.label.value }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {% if card.targetStudyFields|length > 0 %}
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-book-fill me-2 text-secondary mt-1"></i>
                        <div>
                            <small class="text-muted d-block">Filières ciblées</small>
                            {% for field in card.targetStudyFields %}
                                <span class="badge rounded-pill text-wrap text-start" style="background-color: var(--color-ternary); color: var(--color-primary);">{{ field.name }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                <div class="d-flex align-items-center mb-3">
                    <span class="me-2">⭐</span>
                    <div>
                        <small class="text-muted d-block">Favoris</small>
                        <span class="fw-semibold">{{ card.fanUsers|length }} personne{{ card.fanUsers|length > 1 ? 's' : '' }}</span>
                    </div>
                </div>
            </div>

            {# Actions #}
            <div class="shadow-sm rounded-4 p-4 bg-white mb-4">
                <h5 class="fw-bold text-primary raleway-500 mb-3">Actions</h5>
                <div class="d-grid gap-2">
                    <a href="mailto:{{ card.user.email }}" class="btn btn-orange rounded-pill">
                        <i class="bi bi-envelope-fill"></i> Contacter l'auteur
                    </a>
                </div>
            </div>

            {# Auteur #}
            <div class="shadow-sm rounded-4 p-4 bg-white">
                <h5 class="fw-bold text-primary raleway-500 mb-3">A propos de l'auteur</h5>
                <div class="text-center">
                    <div class="user-avatar mx-auto mb-2" style="width:64px; height:64px; font-size:28px;">
                        {% if card.user.avatarFileName %}
                            <img src="{{ asset('uploads/avatars/' ~ card.user.avatarFileName) }}"
                                alt="{{ card.user.firstName }}"
                                style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                        {% else %}
                            <i class="bi bi-person-fill"></i>
                        {% endif %}
                    </div>
                    <div class="fw-bold">{{ card.user.firstName }} {{ card.user.lastName }}</div>
                    {% if card.user.status %}
                        <small class="text-muted">{{ card.user.status.label.value }}</small>
                    {% endif %}
                    {% if card.user.studyField %}
                        <br><small class="text-muted">{{ card.user.studyField.name }}</small>
                    {% endif %}
                    <div class="text-muted mt-1" style="font-size:0.78rem;">
                        Membre depuis {{ card.user.createdAt|date('m/Y') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% if card.images is not empty %}
<script>
    window.galleryImages = [
        {% for image in card.images %}
        { src: "/uploads/cards/{{ image.fileName }}-full.webp", alt: "{{ image.alt ?? card.title|e('js') }}" }{{ not loop.last ? ',' : '' }}
        {% endfor %}
    ];
</script>
{% endif %}

{% endblock %}