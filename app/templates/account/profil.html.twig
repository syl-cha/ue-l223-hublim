{% extends 'account/base_account.html.twig' %}

{% block body_class %}bg-gris{% endblock %}
{% block account_content %}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="fw-bold text-center text-primary raleway-500 my-5">Mon profil</h1>

            {# Affiche le message de succès si le formulaire a été soumis #}
            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    {{ message }}
                </div>
            {% endfor %}

            {% form_theme form 'bootstrap_5_layout.html.twig' %}

            <div class="text-center mb-4">
                {% if app.user.avatarFileName %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatarFileName) }}"
                        class="rounded-circle"
                        style="width: 100px; height: 100px; object-fit: cover;">
                    <div class="mt-2">
                        <form method="post" action="{{ path('app_profile_delete_avatar') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_avatar') }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"
                                    onclick="return confirm('Supprimer la photo de profil ?')">
                                <i class="bi bi-trash me-1"></i> Supprimer la photo
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="user-avatar rounded-circle bg-d-flex align-items-center justify-content-center mx-auto"
                        style="width: 100px; height: 100px;">
                        <span class="text-white fs-1">👤</span>
                    </div>
                {% endif %}
            </div>

            {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                {{ form_row(form.avatarFile) }}
                
                {{ form_row(form.firstName) }}

                {{ form_row(form.lastName) }}

                {{ form_row(form.email) }}

                {{ form_row(form.studyField) }}

                {{ form_row(form.password) }}

                <button type="submit" class="btn btn-lg btn-orange w-100 mt-3">Sauvegarder</button>

            {{ form_end(form) }}

            <hr class="my-5">

            <div class="text-center">
                <h5 class="text-danger fw-bold">Supprimer mon compte</h5>
                <p class="text-muted">Cette action est irréversible. Toutes vos annonces, messages et données seront définitivement supprimés.</p>
                <form method="post" action="{{ path('app_account_delete') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                    <button type="submit" class="btn btn-danger rounded-pill"
                            onclick="return confirm('Êtes-vous sûr(e) de vouloir supprimer votre compte ? Cette action est irréversible.')">
                        <i class="bi bi-trash me-1"></i> Supprimer mon compte
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}