{% extends 'account/base_account.html.twig' %}

{% block body_class %}bg-gris{% endblock %}
{% block account_content %}

<div class="container px-4 pb-5">
    <div class="my-5">
        <h1 class="fw-bold text-center text-primary raleway-500 my-5">Retrouvez toutes vos annonces</h1>
        <div class="d-flex justify-content-between align-items-center pt-3 px-2 mb-4">

            <div>
                <a href="{{ path('app_card_new') }}" class="btn btn-orange rounded-pill px-4">Poster +</a>
            </div>
        </div>
    </div>

    <div class="bento-grid">
        {% for card in cards %}
            {# Vérifier si la carte contient un message signalé #}
            {% set has_flagged_message = false %}
            {% for msg in card.messages %}
                {% if msg.state and msg.state.value == 'flagged' %}
                    {% set has_flagged_message = true %}
                {% endif %}
            {% endfor %}

            <div class="bento-item">
                <div class="bento-item-inner {% if card.state.value == 'draft' %}bento-item-draft{% elseif card.state.value == 'flagged' or has_flagged_message %}bento-item-flagged{% endif %}">

                    {# ── Overlay brouillon ── #}
                    {% if card.state.value == 'draft' %}
                    <div class="bento-overlay bento-overlay-draft">
                        <span class="draft-overlay-label">
                            <i class="bi bi-floppy me-1"></i> Brouillon
                        </span>
                        <div class="overlay-actions">
                            <div class="overlay-action-item">
                                <a href="{{ path('app_card_edit', {'id': card.id}) }}"
                                   class="btn-action-overlay text-decoration-none"
                                   title="Éditer">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <small>Éditer</small>
                            </div>
                        </div>
                    </div>

                    {# ── Overlay signalée ou message signalé ── #}
                    {% elseif card.state.value == 'flagged' or has_flagged_message %}
                    <div class="bento-overlay" style="background: rgba(220, 53, 69, 0.85); padding: 1.5rem;">
                        <div class="draft-overlay-label text-white text-center w-100 d-flex flex-column align-items-center justify-content-center" style="white-space: normal; line-height: 1.4;">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <i class="bi bi-exclamation-triangle-fill fs-3"></i>
                                {% if card.state.value == 'flagged' %}
                                    <span class="fs-5 fw-bold">Annonce signalée</span>
                                {% else %}
                                    <span class="fs-5 fw-bold">Message signalé</span>
                                {% endif %}
                            </div>
                            {% if card.state.value == 'flagged' %}
                                <small class="fw-normal mb-3">en attente de modération</small>
                            {% else %}
                                <small class="fw-normal mb-3">sous cette annonce</small>
                            {% endif %}
                        </div>
                        <div class="overlay-actions mt-0">
                            <div class="overlay-action-item">
                                <a href="{{ path('app_card_show', {'id': card.id}) }}" class="btn btn-sm btn-light rounded-pill px-3 d-flex align-items-center gap-2 text-decoration-none shadow-sm">
                                    <i class="bi bi-eye text-danger"></i>
                                    <span class="text-danger fw-bold">Consulter</span>
                                </a>
                            </div>
                        </div>
                    </div>

                    {# ── Overlay normal ── #}
                    {% else %}
                    <div class="bento-overlay">
                        <a href="{{ path('app_card_show', {'id': card.id}) }}" class="overlay-link">Voir l'annonce →</a>
                        <div class="overlay-actions">
                            <div class="overlay-action-item">
                                {% if app.user %}
                                    <a href="{{ path('app_card_favorite', {'id': card.id}) }}" class="btn-action-overlay text-decoration-none" title="Favori" style="color: var(--color-jaune, #ffc107);">
                                        {% if app.user in card.fanUsers %}
                                            <i class="bi bi-star-fill"></i>
                                        {% else %}
                                            <i class="bi bi-star"></i>
                                        {% endif %}
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_login') }}" class="btn-action-overlay text-decoration-none" title="Favori" style="color: var(--color-jaune, #ffc107);">
                                        <i class="bi bi-star"></i>
                                    </a>
                                {% endif %}
                                <small>Favori</small>
                            </div>
                            <div class="overlay-action-item">
                                <span class="btn-action-overlay" title="Partager">↪</span>
                                <small>Partager</small>
                            </div>
                            <div class="overlay-action-item">
                                <span class="btn-action-overlay" title="Contacter">✉</span>
                                <small>Contacter</small>
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    {# ── Contenu de la carte ── #}
                    <div class="bento-card">
                        {# Badge de statut en haut à droite #}
                        {% if card.state.value == 'draft' %}
                            <div class="draft-status-badge">
                                <i class="bi bi-floppy-fill me-1"></i> Brouillon
                            </div>
                        {% elseif card.state.value == 'flagged' or has_flagged_message %}
                            <div class="draft-status-badge bg-danger text-white">
                                <i class="bi bi-flag-fill me-1"></i> Signalée
                            </div>
                        {% endif %}

                        <div class="user-info">
                            <div class="user-avatar">👤</div>
                            <div class="user-meta">
                                <div class="user-name">
                                    {{ card.user.firstName }} {{ card.user.lastName }}
                                    {% if card.category %}
                                        {% set color = card.category.parent ? card.category.parent.color : card.category.color %}
                                        <span class="fw-normal"> |
                                            <span style="color: {{ color }}">●</span>
                                            <em style="color: {{ color }}">{{ card.category.name }}</em>
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="user-sub">
                                    <span>{{ card.createdAt is defined ? card.createdAt|date('d/m/Y H:i') : 'Date et heure' }}</span>
                                    <span class="ms-2 d-inline-flex align-items-center gap-1">{{ ux_icon('bi:eye') }} <span>{{ card.views is defined ? card.views : 0 }}</span></span>
                                    <span class="ms-2 d-inline-flex align-items-center gap-1">
                                        {% if card.fanUsers|length > 0 %}
                                            {{ ux_icon('bi:star-fill', {class: 'text-warning'}) }}
                                        {% else %}
                                            {{ ux_icon('bi:star') }}
                                        {% endif %}
                                        <span>{{ card.fanUsers|length }}</span>
                                    </span>
                                    {% set visible_messages = card.messages|filter(m => m.state and m.state.value != 'archived') %}
                                    <span class="ms-2 d-inline-flex align-items-center gap-1">{{ ux_icon('bi:chat-right-text') }} <span>{{ visible_messages|length }}</span></span>
                                </div>
                            </div>
                        </div>

                        <div class="card-title">{{ card.title }}</div>

                        <div class="card-description markdown-preview">
                            {{ card.description|markdown_to_html|sanitize_html }}
                        </div>

                        {% if card.coverImage %}
                            <div class="bento-card-image">
                                <img
                                    src="{{ '/uploads/cards/' ~ card.coverImage.fileName ~ '-thumb.webp' }}"
                                        alt="{{ card.coverImage.alt ?? card.title }}"
                                        loading="lazy"
                                >
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="d-flex justify-content-center mt-5">
        {{ knp_pagination_render(cards) }}
    </div>
</div>
{% endblock %}
