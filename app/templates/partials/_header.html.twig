<nav class="d-flex justify-content-between align-items-center py-3 px-4 px-lg-5">
    <div>
        {% if app.user %}
            <a href="{{ path('app_card_index') }}"><img src="{{ asset('svg/logo_hublim_name.svg') }}" alt="Logo HubLim" style="width: 120px;" /></a>
        {% else %}
            <a href="{{ path('app_main') }}"><img src="{{ asset('svg/logo_hublim_name.svg') }}" alt="Logo HubLim" style="width: 120px;" /></a>
        {% endif %}
    </div>

    <ul class="d-none d-lg-flex list-unstyled mb-0">
        <li class="mx-4"><a href="{{ path('app_main') }}" class="text-decoration-none">Accueil</a></li>
        {% if app.user %}
            <li class="mx-4"><a href="{{ path('app_card_index') }}" class="text-decoration-none">Annonces</a></li>
            <li class="mx-4 nav-dropdown">
                <a href="" class="text-decoration-none">Mon espace</a>
                <ul class="dropdown-menu-custom">
                    <li class="dropdown-item-custom">
                        <a href="{{ path('app_mes_annonces') }}">Mes annonces</a>
                    </li>
                    <li class="dropdown-item-custom">
                        <a href="{{ path('app_mes_favoris') }}">Mes favoris</a>
                    </li>
                    <li class="dropdown-item-custom">
                        <a href="{{ path('app_mon_profil') }}">Mon profil</a>
                    </li>
                </ul>
            </li>
        {% endif %}
        {% if not app.user %}
            <li class="mx-4"><a href="#a-propos" class="text-decoration-none">À propos</a></li>
        {% endif %}
        <li class="mx-4"><a href="#footer" class="text-decoration-none">Contact</a></li>
        {% if is_granted('ROLE_ADMIN') %}
            <li class="mx-4">
                <a href="{{ path('app_admin_dashboard') }}" class="text-decoration-none text-danger fw-bold position-relative d-inline-flex align-items-center">
                    <i class="bi bi-shield-lock-fill me-1"></i> Admin
                    {{ render(controller('App\\Controller\\AdminNotificationController::badge')) }}
                </a>
            </li>
        {% endif %}
    </ul>

    <div class="d-none d-lg-block">
        {% if app.user %}
            <a href="{{path('app_logout')}}" class="btn btn-orange">Déconnexion</a>
        {% else %}
            <a href="{{path('app_login')}}" class="btn btn-orange">Accéder aux cartes</a>
        {% endif %}
    </div>

    <button class="nav-hamburger d-lg-none" id="nav-hamburger" aria-label="Ouvrir le menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
    </button>
</nav>

<div class="mobile-menu" id="mobile-menu">
    <button class="mobile-menu-close" id="mobile-menu-close" aria-label="Fermer le menu">
        <i class="bi bi-x-lg"></i>
    </button>
    <ul class="list-unstyled mb-0">
        <li><a href="{{ path('app_main') }}">Accueil</a></li>
        {% if app.user %}
            <li><a href="{{ path('app_card_index') }}">Annonces</a></li>
            <li class="mobile-has-sub">
                <button class="mobile-sub-toggle">Mon espace <i class="bi bi-chevron-down ms-1"></i></button>
                <ul class="mobile-subnav list-unstyled">
                    <li><a href="{{ path('app_mes_annonces') }}">Mes annonces</a></li>
                    <li><a href="{{ path('app_mes_favoris') }}">Mes favoris</a></li>
                    <li><a href="{{ path('app_mon_profil') }}">Mon profil</a></li>
                </ul>
            </li>
        {% endif %}
        {% if not app.user %}
            <li><a href="#a-propos">À propos</a></li>
        {% endif %}
        <li><a href="#footer">Contact</a></li>
        {% if is_granted('ROLE_ADMIN') %}
            <li>
                <a href="{{ path('app_admin_dashboard') }}" class="fw-bold" style="color: #ff8080;">
                    <i class="bi bi-shield-lock-fill me-1"></i> Admin
                </a>
            </li>
        {% endif %}
    </ul>
    <div class="mt-4">
        {% if app.user %}
            <a href="{{path('app_logout')}}" class="btn btn-orange w-100">Déconnexion</a>
        {% else %}
            <a href="{{path('app_login')}}" class="btn btn-orange w-100">Accéder aux cartes</a>
        {% endif %}
    </div>
</div>
