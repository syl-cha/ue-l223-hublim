{% extends 'base.html.twig' %}

{% block title %}Désactiver la double authentification{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <h1 class="h3 mb-3">Désactiver la double authentification</h1>
            <p class="text-muted mb-4">
                {% if method == 'email' %}
                    Pour confirmer la désactivation, entrez le code à 6 chiffres reçu par <strong>email</strong>.
                {% else %}
                    Pour confirmer la désactivation, entrez le code à 6 chiffres depuis votre application d'authentification.
                {% endif %}
            </p>

            <form method="post">
                <div class="mb-3">
                    <label for="code" class="form-label">Code de vérification</label>
                    <input type="text" name="code" id="code" class="form-control text-center"
                           maxlength="6" pattern="[0-9]{6}" inputmode="numeric"
                           placeholder="000000" required autofocus autocomplete="one-time-code">
                </div>
                <button type="submit" class="btn btn-danger w-100">
                    Désactiver la 2FA
                </button>
            </form>

            <p class="text-center mt-3">
                <a href="{{ path('app_card_index') }}" class="text-decoration-none">Annuler</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
