{% extends 'base.html.twig' %}

{% block title %}Choisir la double authentification{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="h3 mb-4 text-center">Activer la double authentification (2FA)</h1>
            <p class="text-muted text-center mb-5">
                Choisissez votre méthode de vérification pour sécuriser votre compte.
            </p>

            <div class="row g-4">
                <!-- Option TOTP -->
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body text-center d-flex flex-column">
                            <div class="mb-3">
                                <i class="bi bi-phone fs-1 text-primary"></i>
                            </div>
                            <h5 class="card-title">Application TOTP</h5>
                            <p class="card-text text-muted flex-grow-1">
                                Utilisez une application comme <strong>Google Authenticator</strong>, <strong>2FAS</strong> ou <strong>Authy</strong> pour générer des codes à 6 chiffres.
                            </p>
                            <a href="{{ path('app_2fa_setup') }}" class="btn btn-orange w-100 mt-3">
                                <i class="bi bi-qr-code me-1"></i> Configurer avec une appli
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Option Email -->
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body text-center d-flex flex-column">
                            <div class="mb-3">
                                <i class="bi bi-envelope fs-1 text-primary"></i>
                            </div>
                            <h5 class="card-title">Code par email</h5>
                            <p class="card-text text-muted flex-grow-1">
                                Recevez un code de vérification par email à chaque connexion. Aucune application requise.
                            </p>
                            <form method="post" action="{{ path('app_2fa_setup_email') }}">
                                <button type="submit" class="btn btn-orange w-100 mt-3">
                                    <i class="bi bi-envelope-check me-1"></i> Activer par email
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
