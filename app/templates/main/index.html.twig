{% extends 'base.html.twig' %}

{% block title %}HubLim - Accueil{% endblock %}

{% block body_class %}home-page{% endblock %}

{% block body %}

<section id="hero-header" class="vh-100 d-flex align-items-center">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <h1 class="display-4 fw-bold raleway-600">Le carrefour numérique de la communauté universitaire de Limoges</h1>
                <p class="lead my-4">Échangez biens, services et idées dans un espace numérique réservé à l'Université de Limoges, authentifié et de confiance.</p>
                <a href="{{ path('app_registration') }}" class="btn btn-orange btn-lg px-5">S'inscrire</a>
            </div>
            <div class="col-lg-5 overflow-hidden">
                <div class="carousel-container collection">
                <img src="{{ asset('images/bg-carousel.png') }}" alt="" class="carousel-bg">
                    {% include 'partials/_carousel.html.twig' %}
                </div>
            </div>
        </div>
    </div>
</section>


{# Section A propos #}

<section id="a-propos" class="py-5">
    <div class="container">
        <div class="row align-items-center pt-5">
            <div class="col-lg-6">
                <h2 class="display-5 fw-bold raleway-500 mb-4 text-secondary">L'esprit HubLim</h2>
                <p class="lead">Plus qu'une simple plateforme, HubLim est le réseau de confiance des étudiants et personnels de l'Université de Limoges.</p>
                <p>Né d'une volonté de favoriser l'économie circulaire et l'entraide locale, nous permettons à chacun de valoriser ses compétences et ses biens au sein d'un environnement sécurisé par l'authentification académique.</p>
            </div>
            <div class="col-lg-6">
                <div class="row g-4">
                    <div class="col-6">
                        <div class="p-4 bg-white shadow-sm rounded text-center">
                            <i class="bi bi-shield-check display-6 text-primary"></i>
                            <h4 class="h6 mt-2">100% Sécurisé</h4>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 bg-white shadow-sm rounded text-center">
                            <i class="bi bi-people display-6 text-primary"></i>
                            <h4 class="h6 mt-2">Communautaire</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row g-4 justify-content-center text-center pt-5">
        <h2 class="mb-5 raleway-500">Comment ça fonctionne ?</h2>
            <div class="col-md-4">
                <div class="step-icon mb-3">
                    <span class="badge rounded-pill bg-secondary px-3 py-2">1</span>
                </div>
                <h3>Inscrivez-vous</h3>
                <p class="text-muted">Utilisez vos identifiants institutionnels pour rejoindre la communauté.</p>
            </div>
            <div class="col-md-4">
                <div class="step-icon mb-3">
                    <span class="badge rounded-pill bg-secondary px-3 py-2">2</span>
                </div>
                <h3>Proposez ou cherchez</h3>
                <p class="text-muted">Publiez vos annonces de services, de vente ou vos idées de projets.</p>
            </div>
            <div class="col-md-4">
                <div class="step-icon mb-3">
                    <span class="badge rounded-pill bg-secondary px-3 py-2">3</span>
                </div>
                <h3>Échangez en confiance</h3>
                <p class="text-muted">Rencontrez vos pairs sur le campus pour finaliser l'échange.</p>
            </div>
        </div>
    </div>
</section>

{# Section Chiffres clés #}

<section id="chiffres-cles" class="py-5">
    <div class="container text-center">
        <h2 class="mb-5 fw-bold raleway-500">Chiffres clés</h2>
        <div class="row g-4 justify-content-center">

            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-people-fill fs-2 text-primary"></i>
                    <span class="fs-1 fw-bold">1 200</span>
                </div>
                <p class="text-muted mt-1">Utilisateurs inscrits</p>
            </div>

            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-megaphone-fill fs-2 text-primary"></i>
                    <span class="fs-1 fw-bold">340</span>
                </div>
                <p class="text-muted mt-1">Annonces publiées</p>
            </div>

            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-arrow-left-right fs-2 text-primary"></i>
                    <span class="fs-1 fw-bold">890</span>
                </div>
                <p class="text-muted mt-1">Échanges réalisés</p>
            </div>

        </div>
    </div>
</section>

{# Section Contact #}

<section id="contact" class="py-5 d-flex align-items-center">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5">
                <h2 class="raleway-500 fw-bold text-secondary">Contactez-nous</h2>
                <p class="pt-3">Une question sur le fonctionnement de la plateforme ou un problème technique ? L'équipe HubLim est là pour vous.</p>
                <ul class="list-unstyled mt-4">
                    <li class="mb-3"><i class="bi bi-envelope me-2 text-primary"></i> contact@hublim.fr</li>
                </ul>
            </div>
            <div class="col-lg-7">
                <form class="row g-3">
                    <div class="col-md-6">
                        <input type="text" class="form-control border-0" placeholder="Nom">
                    </div>
                    <div class="col-md-6">
                        <input type="email" class="form-control border-0" placeholder="Email">
                    </div>
                    <div class="col-12">
                        <textarea class="form-control bg-beige border-0" rows="4" placeholder="Votre message"></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-orange px-5">Envoyer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

{% endblock %}