{% extends 'base.html.twig' %}

{% block title %}Accueil HubLim{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Tableau de bord HubLim</h1>
    </div>
    <hr>

    <div class="row">
        {# Section Utilisateurs #}
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h2 class="h5 mb-0"> Utilisateurs ({{ users|length }})</h2>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Profil</th>
                                <th>Formation</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                                <tr>
                                    <td>
                                        <strong>{{ user.firstName }} {{ user.lastName }}</strong><br>
                                        <small class="text-muted">{{ user.email }}</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary text-white">
                                            {{ user.studyField.type }}
                                        </span>
                                        <span class="badge bg-secondary">
                                            {{ user.studyField.theme }}
                                        </span>
                                        <small class="text-muted">
                                            {{ user.studyField.name }}
                                        </small>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            {{ user.status.label.value|capitalize }}
                                        </span>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="3" class="text-center">Aucun utilisateur en base.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {# Section Cartes #}
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h2 class="h5 mb-0"> Cartes ({{ cards|length }})</h2>
                </div>
                <div class="card-body">
                    <div class="row">
                        {% for card in cards %}
                            <div class="col-12 mb-3">
                                <div class="border rounded p-3">
                                    {% if card.images|length > 0 %}
                                        <img src="{{ card.images[0].fileName }}" 
                                            class="img-fluid rounded mb-3" 
                                            alt="{{ card.title }}"
                                            style="max-height: 300px; width: 100%; object-fit: cover;">
                                    {% endif %}
                                    <div class="d-flex justify-content-between">
                                        <h5 class="text-primary">{{ card.title }}</h5>
                                        <span class="badge 
                                            {% if card.state == constant('App\\Enum\\CardState::DRAFT') %}
                                                bg-warning
                                            {% elseif card.state == constant('App\\Enum\\CardState::PUBLISHED') %}
                                                bg-success
                                            {% elseif card.state == constant('App\\Enum\\CardState::ARCHIVED') %}
                                                bg-dark
                                            {% endif %}">
                                            Statut : {{ card.state.value }}
                                        </span>
                                    </div>
                                    <p class="text-secondary small">{{ card.description }}</p>
                                    
                                    <hr class="my-2">
                                    
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="badge bg-light text-dark border">
                                                {% if card.category.parent %}
                                                    {{ card.category.parent.name }} > {{ card.category.name }}
                                                {% else %}
                                                    {{ card.category.name }}
                                                {% endif %}
                                            </span>
                                        </div>
                                        <small class="text-muted">
                                            Par : <strong>{{ card.user.firstName }}</strong> 
                                            ({{ card.user.studyField.theme }})
                                        </small>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="col-12">
                                <p class="text-muted text-center">Aucune carte trouvée.</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}