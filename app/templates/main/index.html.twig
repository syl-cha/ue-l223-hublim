{% extends 'base.html.twig' %}

{% block title %}HubLim - Accueil{% endblock %}

{% block body_class %}home-page{% endblock %}

{% block body %}

<section id="hero-header" class="vh-100 d-flex align-items-center">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <h1 class="display-4 fw-bold raleway-600">Le carrefour numérique de la communauté universitaire de Limoges</h1>
                <p class="lead my-4">Échangez biens, services et idées dans un espace numérique réservé à l'Université de Limoges, authentifié et de confiance.</p>
                <a href="{{ path('app_register') }}" class="btn btn-orange btn-lg px-5">S'inscrire</a>
            </div>
            <div class="col-lg-5">
                <div class="carousel-container collection">
                    <img src="{{ asset('images/bg-carousel.png') }}" alt="" class="carousel-bg">
                    {% include 'partials/_carousel.html.twig' %}
                </div>
            </div>
        </div>
    </div>
</section>


{# Section A propos #}
<section id="a-propos" class="py-5">
    <div class="container text-center py-5">
        <h2 class="display-5 fw-bold raleway-500 mb-4 text-secondary">L'esprit HubLim</h2>
        <p class="lead mx-auto mb-5" style="max-width: 600px;">
            Plus qu'une simple plateforme, HubLim est le réseau de confiance des étudiants et personnels de l'Université de Limoges, favorisant l'économie circulaire et l'entraide locale.
        </p>
        <div class="row g-4 justify-content-center">
            <div class="col-md-3">
                <div class="p-4 bg-white shadow-sm rounded">
                    <i class="bi bi-door-open display-6 text-primary"></i>
                    <p class="h6 mt-2 mb-0">1. Inscrivez-vous</p>
                    <p class="text-muted small mt-1 mb-0">Via vos identifiants institutionnels</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-4 bg-white shadow-sm rounded">
                    <i class="bi bi-pencil-square display-6 text-primary"></i>
                    <p class="h6 mt-2 mb-0">2. Publiez</p>
                    <p class="text-muted small mt-1 mb-0">Services, vente, projets</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-4 bg-white shadow-sm rounded">
                    <i class="bi bi-chat-heart display-6 text-primary"></i>
                    <p class="h6 mt-2 mb-0">3. Échangez</p>
                    <p class="text-muted small mt-1 mb-0">En confiance sur le campus</p>
                </div>
            </div>
        </div>
    </div>

{# Section Chiffres clés #}

<section id="chiffres-cles" class="py-5">
    <div class="container text-center">
        <h2 class="mb-5 fw-bold raleway-500">Chiffres clés</h2>
        <div class="row g-4 justify-content-center">

            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-people-fill fs-2 text-primary"></i>
                    <span class="fs-1 fw-bold">{{ totalUsers }}</span>
                </div>
                <p class="text-muted mt-1">Utilisateurs inscrits</p>
            </div>

            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-megaphone-fill fs-2 text-primary"></i>
                    <span class="fs-1 fw-bold">{{ totalCards }}</span>
                </div>
                <p class="text-muted mt-1">Annonces publiées</p>
            </div>

            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-arrow-left-right fs-2 text-primary"></i>
                    <span class="fs-1 fw-bold">{{ totalMessages }}</span>
                </div>
                <p class="text-muted mt-1">Échanges réalisés</p>
            </div>

        </div>
    </div>
</section>

{# Section Contact #}

<section id="contact" class="py-5 d-flex align-items-center">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5">
                <h2 class="raleway-500 fw-bold text-secondary">Contactez-nous</h2>
                <p class="pt-3">Une question sur le fonctionnement de la plateforme ou un problème technique ? L'équipe HubLim est là pour vous.</p>
                <ul class="list-unstyled mt-4">
                    <li class="mb-3"><a href="mailto:contact@hublim.bradype.fr" class="text-primary"><i class="bi bi-envelope me-2"></i>contact@hublim.bradype.fr</a></li>
                </ul>
            </div>
            <div class="col-lg-7">
                <form class="row g-3">
                    <div class="col-md-6">
                        <input type="text" class="form-control border border-secondary-subtle" placeholder="Nom">
                    </div>
                    <div class="col-md-6">
                        <input type="email" class="form-control border border-secondary-subtle" placeholder="Email">
                    </div>
                    <div class="col-12">
                        <textarea class="form-control bg-beige border border-secondary-subtle" rows="4" placeholder="Votre message"></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-orange px-5">Envoyer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

{% endblock %}
