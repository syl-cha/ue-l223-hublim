{% extends 'base.html.twig' %}

{% block body_class %}bg-gris{% endblock %}
{% block body %}

<div class="container px-4 pb-5">

    <a href="{{ path('app_card_index') }}" class="btn btn-outline-secondary rounded-pill px-4 mb-4 mt-4">
        <i class="bi bi-arrow-left"></i> Retour aux annonces
    </a>

    <div class="my-5">
        {% if category.parent %}
            <div class="text-center">
                <a href="{{ path('app_category', {slug: category.parent.slug}) }}"
                class="text-decoration-none d-inline-block mb-3 px-3 py-1"
                style="border-radius: 20px; color: {{ category.parent.color }}; transition: background 0.2s;"
                onmouseover="this.style.backgroundColor='{{ category.parent.color }}'; this.style.color='white';"
                onmouseout="this.style.backgroundColor='#f9f9f9'; this.style.color= '{{ category.parent.color }}'">
                    ← {{ category.parent.name }}
                </a>
            </div>
        {% endif %}

        <h1 class="fw-bold text-center text-primary raleway-500 my-5">{{ category.name }}</h1>

        {% if category.subCategories|length > 0 %}
            <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
                {% for sub in category.subCategories %}
                    <a href="{{ path('app_category', {slug: sub.slug}) }}"
                    class="text-decoration-none px-3 py-1"
                    style="border-radius: 20px; color: #223382; font-size: 0.9rem; transition: background 0.2s;"
                    onmouseover="this.style.backgroundColor='{{ category.color }}'; this.style.color='white';"
                    onmouseout="this.style.backgroundColor='#f9f9f9'; this.style.color= '#223382'">
                        {{ sub.name }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        <div class="d-flex justify-content-between align-items-center pt-3 px-2 mb-4">
            <div>
                <a href="{{ path('app_card_new') }}" class="btn btn-orange rounded-pill px-4">Poster +</a>
            </div>

            <div class="d-flex align-items-center gap-3">

                <div class="dropdown">
                    <button class="btn btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown"
                    style="background-color: #e7e6e6; border: none; border-radius: 20px;">
                        Catégories
                    </button>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" href="{{ path('app_card_index') }}">Toutes</a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        {% for category in categories %}
                            <li>
                                <a class="dropdown-item fw-bold" href="{{ path('app_category', {slug: category.slug}) }}">
                                    <span style="color: {{ category.color }}">●</span> {{ category.name }}
                                </a>
                            </li>
                            {% for sub in category.subCategories %}
                                <li>
                                    <a class="dropdown-item ps-4" href="{{ path('app_category', {slug: sub.slug}) }}">
                                        {{ sub.name }}
                                    </a>
                                </li>
                            {% endfor %}
                        {% endfor %}
                    </ul>
                </div>
                
                <form method="get" action="{{ path('card_search') }}">
                    <div class="input-group input-group-sm" style="width: 250px">
                        <input
                            type="text"
                            name="query"
                            class="form-control"
                            placeholder="Rechercher sur HubLim..."
                            autofocus
                            style="border:none; outline:none; box-shadow: none; background-color: #e7e6e6; border-radius: 20px 0px 0px 20px;"
                        >
                        <button class="btn btn-primary" type="submit" style="background-color: #223382; border:none; border-radius: 0 20px 20px 0;">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="bento-grid">
        {% for card in cards %}
            <div class="bento-item">
                <div class="bento-item-inner">
                    <div class="bento-overlay">
                        <a href="{{ path('app_card_show', {'id': card.id}) }}" class="overlay-link">Voir l'annonce →</a>
                        <div class="overlay-actions">
                            <div class="overlay-action-item">
                                {% if app.user %}
                                    <a href="{{ path('app_card_favorite', {'id': card.id}) }}" class="btn-action-overlay text-decoration-none" title="Favori" style="color: var(--color-jaune, #ffc107);">
                                        {% if app.user in card.fanUsers %}
                                            <i class="bi bi-star-fill"></i>
                                        {% else %}
                                            <i class="bi bi-star"></i>
                                        {% endif %}
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_login') }}" class="btn-action-overlay text-decoration-none" title="Favori" style="color: var(--color-jaune, #ffc107);">
                                        <i class="bi bi-star"></i>
                                    </a>
                                {% endif %}
                                <small>Favori</small>
                            </div>
                            <div class="overlay-action-item">
                                <span class="btn-action-overlay" title="Partager">↪</span>
                                <small>Partager</small>
                            </div>
                            <div class="overlay-action-item">
                                <span class="btn-action-overlay" title="Contacter">✉</span>
                                <small>Contacter</small>
                            </div>
                        </div>
                    </div>

                    {# ── Contenu de la carte ── #}
                    <div class="bento-card">
                        <div class="user-info">
                            <div class="user-avatar">👤</div>
                            <div class="user-meta">
                                <div class="user-name">
                                    {{ card.user.firstName }} {{ card.user.lastName }}
                                    {% if card.category %}
                                        {% set color = card.category.parent ? card.category.parent.color : card.category.color %}
                                        <span class="fw-normal"> |
                                            <span style="color: {{ color }}">●</span>
                                            <em style="color: {{ color }}">{{ card.category.name }}</em>
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="user-sub">
                                    <span>{{ card.createdAt is defined ? card.createdAt|date('d/m/Y H:i') : 'Date et heure' }}</span>
                                    <span class="ms-2 d-inline-flex align-items-center gap-1">{{ ux_icon('bi:eye') }} <span>{{ card.views is defined ? card.views : 0 }}</span></span>
                                    <span class="ms-2 d-inline-flex align-items-center gap-1">
                                        {% if card.fanUsers|length > 0 %}
                                            {{ ux_icon('bi:star-fill', {class: 'text-warning'}) }}
                                        {% else %}
                                            {{ ux_icon('bi:star') }}
                                        {% endif %}
                                        <span>{{ card.fanUsers|length }}</span>
                                    </span>
                                    <span class="ms-2 d-inline-flex align-items-center gap-1">{{ ux_icon('bi:chat-right-text') }} <span>{{ card.messages|length }}</span></span>
                                </div>
                            </div>
                        </div>

                        <div class="card-title">{{ card.title }}</div>

                        <div class="card-description markdown-preview">
                            {{ card.description|markdown_to_html|sanitize_html }}
                        </div>

                        {% if card.coverImage %}
                            <div class="bento-card-image">
                                <img
                                    src="{{ '/uploads/cards/' ~ card.coverImage.fileName ~ '-thumb.webp' }}"
                                        alt="{{ card.coverImage.alt ?? card.title }}"
                                        loading="lazy"
                                >
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
        <div class="space text-center my-5">
            <p class="mt-3 fs-5 text-muted">Pas encore de cartes publiées dans cette catégorie.</p>
            <a href="{{ path('app_card_index') }}" class="btn btn-orange px-4 mb-5">
                <i class="bi bi-arrow-left"></i> Parcourir toutes les annonces
            </a>
        </div>
        {% endfor %}
    </div>

    <div class="d-flex justify-content-center mt-5">
        {{ knp_pagination_render(cards) }}
    </div>
</div>
{% endblock %}
